            print(f"    INSERT failed {type(e).__name__}: {e}")

        # Read what actually landed in MariaDB
        if diag_name:
            row = frappe.db.sql(
                "SELECT name, slug FROM `tabRobot Category` WHERE name = %s",
                diag_name,
                as_dict=True,
            )
            print(f"    SQL row: {row}")

        print(f"\n    Step trace ({len(STEPS)} events):")
        for s in STEPS:
            print(f"      {s}")
    finally:
        RobotCategory.validate = original_validate
        RobotCategory._normalize_slug = original_normalize
        Document._sync_autoname_field = original_sync
        for candidate in ("ZZZ-FINAL-UPPER", "zzz-final-upper", diag_name or ""):
            if candidate and frappe.db.exists("Robot Category", candidate):
