        STEPS.append(("_normalize_slug ENTER", "slug=", self.slug))
        r = original_normalize(self)
        STEPS.append(("_normalize_slug EXIT ", "slug=", self.slug))
        return r
2026-06-02 11:58:23,952 INFO ipython     def traced_sync(self):
        STEPS.append(("_sync_autoname_field ENTER", "slug=", self.slug, "name=", self.name))
