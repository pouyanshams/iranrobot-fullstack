2026-06-02 11:58:23,952 INFO ipython     original_normalize = RobotCategory._normalize_slug
2026-06-02 11:58:23,952 INFO ipython     original_sync = Document._sync_autoname_field
2026-06-02 11:58:23,952 INFO ipython     def traced_validate(self):
        STEPS.append(("validate ENTER", "slug=", self.slug, "name=", self.name))
        r = original_validate(self)
        STEPS.append(("validate EXIT ", "slug=", self.slug, "name=", self.name))
        return r
